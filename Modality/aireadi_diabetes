# Data is at ../input/ directly (no Data_Read subfolder)
DATA_ROOT = os.path.abspath(os.path.join(os.getcwd(), "../input"))
# Fallback: walk up to find participants.tsv
if not os.path.exists(os.path.join(DATA_ROOT, "Other_data", "participants.tsv")):
    for _p in ["../input", "../../input", "input"]:
        _candidate = os.path.abspath(os.path.join(os.getcwd(), _p))
        if os.path.exists(os.path.join(_candidate, "Other_data", "participants.tsv")):
            DATA_ROOT = _candidate
            break


