def load_participants() -> pd.DataFrame:
    """Load the participants TSV.

    Returns a DataFrame with columns:
      person_id, clinical_site, study_group, age, study_visit_date,
      recommended_split, cardiac_ecg, clinical_data, environment,
      retinal_flio, retinal_oct, retinal_octa, retinal_photography,
      wearable_activity_monitor, wearable_blood_glucose

    study_group values: 'healthy', 'pre_diabetes_lifestyle_controlled',
      'oral_medication_and_or_non_insulin_injectable_medication_controlled',
      'insulin_dependent'
    """
    path = os.path.join(DATA_ROOT, "Other_data", "participants.tsv")
    df = pd.read_csv(path, sep="\t")
    # Convert TRUE/FALSE strings to booleans
    bool_cols = ["cardiac_ecg", "clinical_data", "environment", "retinal_flio",
                 "retinal_oct", "retinal_octa", "retinal_photography",
                 "wearable_activity_monitor", "wearable_blood_glucose"]
    for c in bool_cols:
        if c in df.columns:
            df[c] = df[c].map({"TRUE": True, "FALSE": False, True: True, False: False})
    # IMPORTANT: Only 12 participants have actual data files in this local copy.
    # Filter to participants who have at least one data file present on disk.
    cgm_dir = os.path.join(DATA_ROOT, "wearable_blood_glucose", "continuous_glucose_monitoring", "dexcom_g6")
    if os.path.exists(cgm_dir):
        available_ids = set(int(p) for p in os.listdir(cgm_dir) if p.isdigit())
        df = df[df["person_id"].isin(available_ids)].reset_index(drop=True)
    return df


def get_study_group_label(study_group: str) -> int:
    """Map study group string to integer label (0=healthy, 1=pre-DM, 2=oral/inject, 3=insulin)."""
    mapping = {
        "healthy": 0,
        "pre_diabetes_lifestyle_controlled": 1,
        "oral_medication_and_or_non_insulin_injectable_medication_controlled": 2,
        "insulin_dependent": 3,
    }
    return mapping.get(study_group, -1)


# ─────────────────────────────────────────────────────────────────────────────
# 2. CLINICAL DATA (OMOP CDM)
